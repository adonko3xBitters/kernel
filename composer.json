{
    "name": "ausus/kernel",
    "type": "library",
    "description": "AUSUS Kernel — contracts, value objects, DSL facade. RFC-001 + contract surfaces of RFC-005 §2, RFC-013 §2, RFC-014 §2.",
    "license": "MIT",
    "keywords": ["ausus", "framework", "metadata", "kernel"],
    "homepage": "https://github.com/adonko3xBitters/kernel",
    "require": {
        "php": ">=8.3"
    },
    "autoload": {
        "classmap": ["src/"]
    },
    "autoload-dev": {
        "psr-4": {
            "Ausus\\Kernel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "ausus": {
            "layer": "L0",
            "role": "kernel"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
